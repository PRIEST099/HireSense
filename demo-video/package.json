    "@remotion/shapes": "^4.0.250",
    "@remotion/transitions": "^4.0.250",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.250"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.0"
  }
}
