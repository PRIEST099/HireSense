{
  "name": "hiresense-demo-video",
  "version": "1.0.0",
  "description": "Programmatic demo video for HireSense AI built with Remotion",
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion render HireSenseDemo out/HireSense-Demo.mp4 --concurrency=4",
